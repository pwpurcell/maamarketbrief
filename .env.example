# Resend daily-email config (Phase 6) — get the API key from https://resend.com
# Set ENABLE_DAILY_EMAIL=true once you've verified your sending domain in Resend.
RESEND_API_KEY=re_...
EMAIL_FROM=brief@yourdomain.com
EMAIL_TO=paul@example.com
ENABLE_DAILY_EMAIL=false

# Deploy / scheduling (Phase 7).
DOMAIN=brief.yourdomain.com
TIMEZONE=Australia/Melbourne
REFRESH_INTERVAL_MINUTES=15
